+async def benchmark(
+    request_func,
+    api_url: str,
+    model_id: str,
+    model_name: str,
+    input_requests: list[tuple[str, int, int]],
+    logprobs: Optional[int],
+    best_of: int,
+    request_rate: float,
+    burstiness: float,
+    sampling_params: Optional[dict],
+    disable_tqdm: bool,
+    ignore_eos: bool,
+    max_concurrency: Optional[int],
+    lora_modules: Optional[list[str]],
+    bench_start_barrier: Optional[asyncio.Barrier] = None,
+    process_id: int = -1,
+    tqdm_bar_q: Optional[Queue] = None,
+):
+    if lora_modules:
+        # For each input request, choose a LoRA module at random.
+        lora_modules = iter(
+            [random.choice(lora_modules) for _ in range(len(input_requests))])
+
+    if burstiness == 1.0:
+        distribution = "Poisson process"
+    else:
+        distribution = "Gamma distribution"
+
+    print(f"benchmark process <{process_id}>: Traffic request rate: {request_rate}")
+    print(f"benchmark process <{process_id}>: Burstiness factor: {burstiness} ({distribution})")
+    print(f"benchmark process <{process_id}>: Maximum request concurrency: {max_concurrency}")
+
+    pbar = None
+    # This can be used once the minimum Python version is 3.10 or higher,
+    # and it will simplify the code in limited_request_func.
+    #    semaphore = (asyncio.Semaphore(max_concurrency)
+    #                 if max_concurrency else contextlib.nullcontext())
+    semaphore = (asyncio.Semaphore(max_concurrency)
+                 if max_concurrency else None)
+
+    async def limited_request_func(request_func_input, pbar, process_id, tqdm_bar_q, disable_tqdm):
+        if semaphore is None:
+            res = await request_func(request_func_input=request_func_input,
+                                      pbar=pbar)
+        else:
+            async with semaphore:
+                res = await request_func(request_func_input=request_func_input,
+                                          pbar=pbar)
+        if not disable_tqdm:
+            tqdm_bar_q.put((process_id, 1))
+        return res
+
+    benchmark_start_time = time.perf_counter()
+    tasks: list[asyncio.Task] = []
+    bench_start_barrier.wait()
+    async for request in get_request(input_requests, request_rate, burstiness):
+        prompt, prompt_len, output_len, mm_content = request
+        req_model_id, req_model_name = model_id, model_name
+        if lora_modules:
+            req_lora_module = next(lora_modules)
+            req_model_id, req_model_name = req_lora_module, req_lora_module
+
+        request_func_input = RequestFuncInput(model=req_model_id,
+                                              model_name=req_model_name,
+                                              prompt=prompt,
+                                              api_url=api_url,
+                                              prompt_len=prompt_len,
+                                              output_len=output_len,
+                                              logprobs=logprobs,
+                                              best_of=best_of,
+                                              multi_modal_content=mm_content,
+                                              ignore_eos=ignore_eos,
+                                              extra_body=sampling_params)
+        tasks.append(
+            asyncio.create_task(
+                limited_request_func(request_func_input=request_func_input,
+                                     pbar=pbar,
+                                     process_id=process_id,
+                                     tqdm_bar_q=tqdm_bar_q,
+                                     disable_tqdm=disable_tqdm)))
+    outputs: list[RequestFuncOutput] = await asyncio.gather(*tasks)
+
+    if not disable_tqdm:
+        tqdm_bar_q.put((process_id, None))
+    benchmark_end_time = time.perf_counter()
+    return outputs, benchmark_start_time, benchmark_end_time
+
+
+def worker_process(
+    request_func,
+    args: argparse.Namespace,
+    api_url: str,
+    sub_requests,
+    sub_max_concurrency,
+    sub_request_rate,
+    benchmark_outputs,
+    sampling_params,
+    bench_start_barrier,
+    process_id,
+    tqdm_bar_q
+):
+    loop = asyncio.new_event_loop()
+    asyncio.set_event_loop(loop)
+
+    sub_result = loop.run_until_complete(
+        benchmark(
+            request_func=request_func,
+            api_url=api_url,
+            model_id=args.model,
+            model_name=args.served_model_name,
+            input_requests=sub_requests,
