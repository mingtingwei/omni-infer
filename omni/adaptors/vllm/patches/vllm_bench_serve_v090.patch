+async def iter_chunks(response, encoding="utf-8"):
+    buffer = ""
+    async for chunk in response.content.iter_any():
+        text = chunk.decode(encoding, errors="ignore")
+        buffer += text
+        while "\n" in buffer:
+            line, buffer = buffer.split("\n", 1)
+            yield line
+    if buffer:
+        yield buffer
